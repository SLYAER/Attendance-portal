rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && (request.auth.token.email == 'loveranger900@gmail.com' || request.auth.token.email == 'ascendservices.corp@gmail.com');
    }

    function existing() {
      return resource.data;
    }

    function incoming() {
      return request.resource.data;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        !('password' in resource.data) && 
        'password' in request.resource.data && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['password'])
      );
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /attendance/{recordId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }
    
    match /failed_attempts/{recordId} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }
    
    match /daily_codes/{dayId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }
  }
}
